{
    "extends": "@vue/tsconfig/tsconfig.dom.json",
    "include": [
        "env.d.ts",
        "src/**/*",
        "src/**/*.vue",
        "vite.config.*",
        "vitest.config.*",
        "cypress.config.*",
        "nightwatch.conf.*",
        "playwright.config.*"
    ],
    "exclude": ["src/**/__tests__/*"],
    "compilerOptions": {
        "composite": false,
        "noEmit": true,
        "baseUrl": ".",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "types": ["node"],
        "paths": {
            "@/*": ["./src/*"]
        }
    }
}
